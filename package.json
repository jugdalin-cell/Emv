{
  "name": "x2-javacard-writer",
  "version": "3.2.0",
  "description": "X2 JavaCard Writer with Enhanced J2A040 Support - Real Card Reader Integration",
  "main": "main.js",
  "type": "module",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --verbose",
    "build": "electron-builder",
    "build-win": "electron-builder --win",
    "build-all": "electron-builder -mwl"
  },
  "dependencies": {
    "pcsclite": "^1.3.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.x2ist.javacard",
    "productName": "X2 JavaCard Writer",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "node_modules/pcsclite/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
